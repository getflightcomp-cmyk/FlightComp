{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "crons": [
    {
      "path": "/api/cron/send-reminders-24h",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/send-reminders-72h",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/kit-followup",
      "schedule": "0 9 * * *"
    }
  ]
}
